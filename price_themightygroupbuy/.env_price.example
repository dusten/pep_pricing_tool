# =============================================================
# TheMightyGroupBuy Price Comparison — environment config
# Copy to .env_price and fill in values. Never commit .env_price.
# =============================================================

# ── App ───────────────────────────────────────────────────────
APP_ENV=production
APP_URL=https://price.themightygroupbuy.com
APP_SECRET=change-me-to-a-long-random-string

# ── Database ──────────────────────────────────────────────────
DB_HOST=127.0.0.1
DB_PORT=3306
DB_NAME=tmgb_price
DB_USER=pc_user
DB_PASS=CHANGE_ME

# ── Memcached ─────────────────────────────────────────────────
MC_HOST=127.0.0.1
MC_PORT=11211

# ── Email (Brevo) ─────────────────────────────────────────────
BREVO_API_KEY=your-brevo-api-key

# ── Anthropic (Phase 3 — Claude extraction pipeline) ──────────
ANTHROPIC_API_KEY=your-anthropic-api-key

# ── Stripe (Phase 2 — billing) ────────────────────────────────
STRIPE_SECRET_KEY=sk_live_...
STRIPE_WEBHOOK_SECRET=whsec_...

# Stripe Price IDs (create these in the Stripe dashboard)
STRIPE_PRICE_ADV_MONTHLY=price_...
STRIPE_PRICE_ADV_ANNUAL=price_...
STRIPE_PRICE_PRO_MONTHLY=price_...
STRIPE_PRICE_PRO_ANNUAL=price_...
STRIPE_PRICE_EXPERT_MONTHLY=price_...
STRIPE_PRICE_EXPERT_ANNUAL=price_...
