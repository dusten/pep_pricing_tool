Options -Indexes +FollowSymLinks
RewriteEngine On

# 1. Serve real files directly (JS/CSS/images in dist/)
RewriteCond %{REQUEST_FILENAME} -f
RewriteRule ^ - [L]

# 2. Serve real directories
RewriteCond %{REQUEST_FILENAME} -d
RewriteRule ^ - [L]

# 3. Everything (API + SPA routes) → front controller
RewriteRule ^ index.php [L,QSA]
