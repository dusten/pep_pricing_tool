# /etc/cron.d/price
# TheMightyGroupBuy Price Comparison — scheduled tasks
# Installed by setup.sh / add-price-site.sh
# Uses ~/.pc_my.cnf for credentials (written by setup scripts)

SHELL=/bin/bash
PATH=/sbin:/bin:/usr/sbin:/usr/bin
MAILTO=""

# Clean expired sessions (daily 03:00)
0 3 * * * ec2-user mysql --defaults-file=/home/ec2-user/.pc_my.cnf -e "DELETE FROM pc_sessions WHERE expires_at < NOW(); INSERT INTO pc_maintenance_runs (job, status) VALUES ('clean_expired_sessions','ok');" 2>/dev/null

# Clean expired password resets (daily 03:05)
5 3 * * * ec2-user mysql --defaults-file=/home/ec2-user/.pc_my.cnf -e "DELETE FROM pc_password_resets WHERE expires_at < NOW(); INSERT INTO pc_maintenance_runs (job, status) VALUES ('clean_expired_password_resets','ok');" 2>/dev/null

# Clean query log beyond 73h (daily 03:10)
10 3 * * * ec2-user mysql --defaults-file=/home/ec2-user/.pc_my.cnf -e "DELETE FROM pc_query_log WHERE created_at < DATE_SUB(NOW(), INTERVAL 73 HOUR); INSERT INTO pc_maintenance_runs (job, status) VALUES ('clean_query_log','ok');" 2>/dev/null

# 90-day perf metric retention (daily 03:15)
15 3 * * * ec2-user mysql --defaults-file=/home/ec2-user/.pc_my.cnf -e "DELETE FROM pc_perf_metrics WHERE created_at < DATE_SUB(NOW(), INTERVAL 90 DAY); INSERT INTO pc_maintenance_runs (job, status) VALUES ('clean_perf_metrics','ok');" 2>/dev/null

# Weekly table optimization (Sunday 04:00) — surfaced in Admin > System
0 4 * * 0 ec2-user mysql --defaults-file=/home/ec2-user/.pc_my.cnf -e "OPTIMIZE TABLE pc_prices, pc_query_log, pc_comparison_log, pc_perf_metrics; INSERT INTO pc_maintenance_runs (job, status, details) VALUES ('optimize_tables','ok','pc_prices, pc_query_log, pc_comparison_log, pc_perf_metrics');" 2>/dev/null

# Daily table analyze — refreshes index cardinality stats for the query optimizer.
# Cheap (no rebuild/lock like OPTIMIZE), so runs daily rather than weekly. Surfaced in Admin > System.
30 3 * * * ec2-user mysql --defaults-file=/home/ec2-user/.pc_my.cnf -e "ANALYZE TABLE pc_prices, pc_products, pc_specifications, pc_vendors, pc_query_log, pc_comparison_log, pc_perf_metrics; INSERT INTO pc_maintenance_runs (job, status, details) VALUES ('analyze_tables','ok','pc_prices, pc_products, pc_specifications, pc_vendors, pc_query_log, pc_comparison_log, pc_perf_metrics');" 2>/dev/null

# Async vendor file processing — picks up large PDFs that files/process.php
# queued instead of calling Claude inline (every 5 min; uses .env_pricetool
# via config.php, not the mysql options file, since it's a PHP script).
*/5 * * * * ec2-user php /home/ec2-user/price_themightygroupbuy/backend/cron/process_async_queue.php >> /home/ec2-user/price_themightygroupbuy/log/cron.log 2>&1
