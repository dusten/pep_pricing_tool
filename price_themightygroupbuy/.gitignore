# Environment — never commit
.env_pricetool

# Dependencies
node_modules/
frontend/node_modules/
frontend/.vite/

# Build output
public/dist/
frontend/dist/assets/

# Vendor lib blobs (placed manually)
backend/lib/fpdi/
backend/lib/font/
backend/public/assets/

# Frontend env
frontend/.env

# Uploaded vendor files — excluded from rsync too
backend/storage/vendor_files/

# ClamAV signature files — downloaded locally (clamav.net CDN blocks this EC2
# range), synced by deploy.sh, never committed
clamav-db/*.cvd
clamav-db/*.cld

# Email log files (directory tracked via .gitkeep)
log/*.log

# OS / editor
.DS_Store
Thumbs.db
.idea/
.vscode/
*.swp
